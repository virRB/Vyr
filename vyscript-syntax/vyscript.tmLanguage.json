{
  "name": "VyScript",
  "scopeName": "source.vyscript",
  "fileTypes": ["vy"],
  "patterns": [
    {
      "name": "keyword.control.vyscript",
      "match": "\\b(func|if|for|return)\\b"
    },
    {
      "name": "support.type.vyscript",
      "match": "\\b(addInScript|alis)\\b"
    },
    {
      "name": "keyword.operator.arrow.vyscript",
      "match": "->"
    },
    {
      "name": "string.quoted.double.vyscript",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.vyscript",
      "match": "\\b\\d+\\b"
    },
    {
      "name": "comment.line.vyscript",
      "match": "#.*$"
    },
    {
      "name": "variable.other.vyscript",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}